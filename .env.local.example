# Copy this to .env.local for local development

# ── Supabase (required for production / real match data) ──────────────────────
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# ── Mock mode (no Supabase / no CricAPI needed) ───────────────────────────────
# Set to "true" to use local IPL fixture data from src/test/fixtures/mockMatches.ts
# This gives you 1 live match + 3 upcoming IPL fixtures so you can test the full
# game flow without any network calls or API key.
VITE_USE_MOCK_DATA=false
VITE_ENABLE_PITCH_PAISA_DEV_OVERRIDE=true
